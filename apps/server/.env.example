# Copy to .env and adjust. Never commit real secrets.

# Postgres (docker-compose.dev.yml defaults)
DATABASE_URL=postgres://emberchat:emberchat@localhost:5432/emberchat

# Secret for signing access tokens — at least 32 characters. The server
# refuses to start with this placeholder value.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=dev-only-secret-change-me-0000000000

HOST=127.0.0.1
PORT=3000

# REQUIRED when running behind a reverse proxy (nginx/traefik), or per-IP
# rate limits key on the proxy address — one shared bucket for every client.
# Accepts true/false, a hop count, or comma-separated addresses/CIDRs.
# TRUST_PROXY=1

# F-Chat endpoints. Point both at fchat-sim during development.
# FCHAT_URL=ws://127.0.0.1:9090/chat2
# FLIST_API_URL=http://127.0.0.1:9090
FCHAT_URL=wss://chat.f-list.net/chat2
FLIST_API_URL=https://www.f-list.net
# F-List JSON API pacing. 1000 (1 req/s) is the developer-policy budget —
# only lower it when FLIST_API_URL points at a local fchat-sim.
# FLIST_API_MIN_INTERVAL_MS=1000

# Branding is runtime config (decisions.md §5) — the working title lives here,
# not in code.
APP_NAME=EmberChat
APP_BASE_URL=http://localhost:3000

# IDN cname/cversion — honest and unique per the F-List developer policy.
CLIENT_NAME=EmberChat
CLIENT_VERSION=0.0.0

# Comma-separated allowed browser origins (the Vite dev server in development).
CORS_ORIGIN=http://localhost:5173
