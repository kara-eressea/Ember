# Copy to .env and adjust. Never commit real secrets.

# Postgres (docker-compose.dev.yml defaults)
DATABASE_URL=postgres://emberline:emberline@localhost:5432/emberline

# Secret for signing access tokens — at least 32 characters.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=dev-only-secret-change-me-0000000000

HOST=127.0.0.1
PORT=3000

# F-Chat endpoints. Point both at fchat-sim during development.
# FCHAT_URL=ws://127.0.0.1:9090/chat2
# FLIST_API_URL=http://127.0.0.1:9090
FCHAT_URL=wss://chat.f-list.net/chat2
FLIST_API_URL=https://www.f-list.net

# Branding is runtime config (decisions.md §5) — the working title lives here,
# not in code.
APP_NAME=Emberline
APP_BASE_URL=http://localhost:3000

# IDN cname/cversion — honest and unique per the F-List developer policy.
CLIENT_NAME=Emberline
CLIENT_VERSION=0.0.0

# Comma-separated allowed browser origins (the Vite dev server in development).
CORS_ORIGIN=http://localhost:5173
