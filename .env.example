# docker-compose deployment config — copy to .env and set real values.
# (apps/server/.env.example is the separate host-development config.)
# Never commit real secrets. Full walkthrough: docs/self-hosting.md

# ── Required ─────────────────────────────────────────────────────────────────

# Postgres superuser password for the bundled postgres service.
POSTGRES_PASSWORD=change-me

# Secret for signing access tokens — at least 32 characters. The server
# refuses to start with the placeholder from apps/server/.env.example.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=

# ── Image & listening ────────────────────────────────────────────────────────

# Which ghcr tag to run: vX.Y.Z (exact) | vX.Y (compatible) | latest | edge.
#IMAGE_TAG=latest

# Where the server listens on the host. Default binds loopback only —
# put a TLS-terminating reverse proxy in front and set TRUST_PROXY.
#BIND_ADDRESS=127.0.0.1
#PORT=3000
#TRUST_PROXY=1

# ── F-Chat ───────────────────────────────────────────────────────────────────

# Defaults are the real service; for the smoke profile:
#FCHAT_URL=ws://sim:9090/chat2
#FLIST_API_URL=http://sim:9090

# ── Branding ─────────────────────────────────────────────────────────────────

# Branding is runtime config (decisions.md §5); renaming the product is an
# .env change + restart, no rebuild.
#APP_NAME=EmberChat
#APP_BASE_URL=https://your-domain.example

# IDN cname — honest and unique per the F-List developer policy. The
# version is baked into the image by the release workflow.
#CLIENT_NAME=EmberChat

# ── Retention & logs ─────────────────────────────────────────────────────────

# Message retention: forever (default) | 30d | 90d | 1y. Age policies
# delete history older than the cutoff on each sweep. Your logs' location:
# the messages table in the Postgres volume (F-List developer policy: logs
# must be known and accessible to the user).
#RETENTION_POLICY=forever

# ── Profiles (M8) ────────────────────────────────────────────────────────────

# Character-data requests allowed per sliding hour (profile views, guestbook
# pages). F-List allows 200/hour; the 170 default leaves headroom — do NOT
# raise this above the currently published limit. When exhausted, cached
# profiles are served stale until the window frees up.
#CHARACTER_DATA_BUDGET_PER_HOUR=170

# How long a cached profile stays fresh before a view refetches it (ms).
#PROFILE_CACHE_TTL_MS=86400000

# Bulk mapping-list (infotags/kinks/listitems) refresh window (ms). These
# are ticketless, cheap, and drift rarely — a week is plenty.
#FLIST_MAPPINGS_TTL_MS=604800000

# Eicon search index host (M8). Only contacted when a user enables the
# eiconSearchEnabled preference: the server downloads the bulk index and
# searches it locally — user queries never leave the server.
#EICON_INDEX_BASE_URL=https://xariah.net

# How often the eicon index delta-refreshes (ms, ~daily upstream).
#EICON_INDEX_REFRESH_MS=86400000

# ── Updates & upgrades ───────────────────────────────────────────────────────

# Daily update check against the GitHub Releases API (a quiet "update
# available" hint in the UI). Reveals the instance's existence to GitHub,
# nothing more; set false to disable the phone-home.
#UPDATE_CHECK_ENABLED=true

# One-boot acknowledgment when an upgrade crosses a migration flagged
# BREAKING — the server refuses to start otherwise. Back up first, read the
# release notes, set true for one boot, then remove it.
#CONFIRM_BREAKING_UPGRADE=false

# ── Backups ──────────────────────────────────────────────────────────────────

# The backup service pg_dumps into BACKUP_DIR on this schedule and prunes
# dumps older than BACKUP_KEEP_DAYS. Restore drill: docs/self-hosting.md.
#BACKUP_DIR=./backups
#BACKUP_INTERVAL_SECONDS=86400
#BACKUP_KEEP_DAYS=14
